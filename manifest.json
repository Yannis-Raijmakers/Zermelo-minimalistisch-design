{
  "manifest_version": 3,
  "name": "Zermelo Liquid Glass",
  "version": "1.1.0",
  "description": "Apple-achtige liquid glass/glassmorphism redesign voor Zermelo met light/dark toggle.",
  "content_scripts": [
    {
      "matches": [
        "https://*.zermelo.nl/*",
        "https://*.zportal.nl/*"
      ],
      "css": [
        "dark-modern.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
